{
  "name": "altianly",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.0",
    "@react-navigation/native-stack": "^7.17.2",
    "expo": "~56.0.9",
    "expo-secure-store": "^56.0.4",
    "expo-sqlite": "~56.0.0",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.24.0",
    "react-native-svg": "^15.15.5",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.39.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "node -e \"require('fs').rmSync('.expo',{recursive:true,force:true})\" && expo export --platform web && node -e \"const f=require('fs');f.mkdirSync('dist/app',{recursive:true});f.renameSync('dist/index.html','dist/app/index.html');f.copyFileSync('public/altianly-homepage.html','dist/index.html');f.cpSync('public','dist',{recursive:true,force:true})\"",
    "typecheck": "tsc --noEmit --skipLibCheck",
    "lint": "eslint src/"
  },
  "private": true
}
